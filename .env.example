# ─── PhishGuard Backend — Environment Variables ───────────────────────────────
# Salin file ini ke .env dan isi nilainya

# App
DEBUG=false
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter

# Database (Railway otomatis set DATABASE_URL jika pakai PostgreSQL plugin)
DATABASE_URL=sqlite+aiosqlite:///./phishguard.db

# Redis (Railway otomatis set REDIS_URL jika pakai Redis plugin)
# Tanpa Redis, rate limiting pakai in-memory (tidak persist antar restart)
REDIS_URL=memory://

# ─── Free API Keys ─────────────────────────────────────────────────────────────
# Google Safe Browsing — 10.000 req/hari GRATIS
# Daftar di: https://console.cloud.google.com/ → APIs → Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# PhishTank — gratis, daftar di: https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# VirusTotal — 4 req/menit gratis: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# ─── CORS ───────────────────────────────────────────────────────────────────────
# URL frontend Railway kamu (setelah deploy)
ALLOWED_ORIGINS=["http://localhost:5173","https://phishguard-frontend.up.railway.app"]
